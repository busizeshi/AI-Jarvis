# ============ 拾笺 NoteGather · Python AI 端环境变量示例 ============
# 复制为 .env.dev 后按需修改；生产环境通过配置中心 / K8s Secret 注入

# ---- 服务端口 ----
PARSE_GRPC_PORT=50051
PARSE_HTTP_PORT=8001
SEARCH_GRPC_PORT=50052

# ---- MySQL（可选，解析状态回写主要走 RocketMQ）----
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=notegather
MYSQL_USER=ng
MYSQL_PASSWORD=ng123456

# ---- Qdrant 向量库 ----
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=true

# ---- Elasticsearch ----
ES_HOST=localhost
ES_PORT=9200
ES_SCHEME=http
ES_USERNAME=
ES_PASSWORD=

# ---- MinIO 对象存储（宿主机端口 9100，见 docker-compose）----
MINIO_ENDPOINT=localhost:9100
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=notegather

# ---- RocketMQ ----
ROCKETMQ_NAMESRV=localhost:9876
ROCKETMQ_FILE_TOPIC=NG_FILE_TOPIC
ROCKETMQ_CONSUMER_GROUP=ng_parse_consumer_group

# ---- 嵌入模型 ----
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_USE_FP16=false

# ---- 文本分块 ----
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ---- LLM（LiteLLM 统一接口）----
LLM_MODEL=gpt-4o-mini
LLM_API_BASE=
LLM_API_KEY=your-api-key-here
LLM_TEMPERATURE=0.3

# ---- 检索参数 ----
RETRIEVE_TOP_K=10
RERANK_TOP_K=5

# ---- 日志 ----
LOG_LEVEL=INFO
